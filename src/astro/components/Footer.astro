<footer class="py-14 md:py-20 lg:py-24 px-6" style="background-color: #1B4229;">
  <div class="container mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
      <div class="col-span-1 md:col-span-2">
        <img src="/assets/footer-logo.svg" alt="ATTIMO" class="h-16 mb-4" />
      </div>
      <div class="hidden md:block"></div>
      <div class="hidden md:flex justify-end">
        <a href="https://www.instagram.com/attimo.oil" target="_blank" rel="noopener noreferrer" class="hover:opacity-80 transition-opacity" aria-label="Instagram">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#B3E58C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Mobile -->
    <div class="md:hidden">
      <div class="flex justify-between items-start mb-6">
        <div class="flex flex-col gap-3 text-sm" style="font-family: 'Space Grotesk', sans-serif;">
          <a href="/blog" class="hover:underline transition-colors" style="color: #B3E58C;">Blog</a>
          <a href="/privacy" class="hover:underline transition-colors" style="color: #B3E58C;">Privacy Policy</a>
          <a href="/terms" class="hover:underline transition-colors" style="color: #B3E58C;">Terms of Service</a>
          <a href="/shipping" class="hover:underline transition-colors" style="color: #B3E58C;">Shipping</a>
          <a href="/contact" class="hover:underline transition-colors" style="color: #B3E58C;">Contact</a>
          <a href="https://shop.attimo-oil.com/account" class="hover:underline transition-colors" style="color: #B3E58C;">Manage Orders & Subscription</a>
        </div>
        <a href="https://www.instagram.com/attimo.oil" target="_blank" rel="noopener noreferrer" class="hover:opacity-80 transition-opacity" aria-label="Instagram">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#B3E58C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
          </svg>
        </a>
      </div>
      <div class="border-t pt-4" style="border-color: #B3E58C;">
        <p class="text-sm" style="font-family: 'Space Grotesk', sans-serif; color: #B3E58C;">© 2026 ATTIMO. All rights reserved.</p>
      </div>
    </div>

    <!-- Desktop -->
    <div class="hidden md:block border-t pt-6" style="border-color: #B3E58C;">
      <div class="flex justify-between items-center gap-4">
        <p class="text-sm" style="font-family: 'Space Grotesk', sans-serif; color: #B3E58C;">© 2026 ATTIMO. All rights reserved.</p>
        <div class="flex gap-6 text-sm" style="font-family: 'Space Grotesk', sans-serif;">
          <a href="/blog" class="hover:underline transition-colors" style="color: #B3E58C;">Blog</a>
          <a href="/privacy" class="hover:underline transition-colors" style="color: #B3E58C;">Privacy Policy</a>
          <a href="/terms" class="hover:underline transition-colors" style="color: #B3E58C;">Terms of Service</a>
          <a href="/shipping" class="hover:underline transition-colors" style="color: #B3E58C;">Shipping</a>
          <a href="/contact" class="hover:underline transition-colors" style="color: #B3E58C;">Contact</a>
          <a href="https://shop.attimo-oil.com/account" class="hover:underline transition-colors" style="color: #B3E58C;">Manage Orders & Subscription</a>
        </div>
      </div>
    </div>
