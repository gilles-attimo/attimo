---
import "@astro/styles/global.css";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogTitle?: string;
  ogImage?: string;
  ogType?: string;
  noIndex?: boolean;
  bodyClass?: string;
  bodyStyle?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  canonical,
  ogTitle,
  ogImage = "https://attimo-oil.com/images/attimo_og.png",
  ogType = "website",
  noIndex = false,
  bodyClass = "",
  bodyStyle = "background-color: #FAF9F6;",
  jsonLd,
} = Astro.props;

const socialTitle = ogTitle ?? title;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, "https://attimo-oil.com").toString();

const jsonLdArray = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang="en">
  <head>
    <script id="consentmo-gcmv2-advanced-mode-integration" is:inline>
      const consentOutOfRegion = { analytics: true, marketing: true, functionality: true, adsDataRedaction: false, urlPassthrough: false };
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('consent', 'default', { ad_storage: 'denied', ad_personalization: 'denied', ad_user_data: 'denied', analytics_storage: 'denied', functionality_storage: 'denied', personalization_storage: 'denied', security_storage: 'granted', wait_for_update: 1500 });
      document.addEventListener('consentmoSignal_onLoad', function(eventData) {
        const csmLoadSignal = eventData.detail || {isActive:false};
        if (!csmLoadSignal.isActive) {
          gtag('consent', 'update', { ad_storage: consentOutOfRegion.marketing ? 'granted' : 'denied', ad_personalization: consentOutOfRegion.marketing ? 'granted' : 'denied', ad_user_data: consentOutOfRegion.marketing ? 'granted' : 'denied', analytics_storage: consentOutOfRegion.analytics ? 'granted' : 'denied', functionality_storage: consentOutOfRegion.functionality ? 'granted' : 'denied', personalization_storage: consentOutOfRegion.functionality ? 'granted' : 'denied', security_storage: 'granted' });
          gtag('set', 'ads_data_redaction', consentOutOfRegion.adsDataRedaction);
          gtag('set', 'url_passthrough', consentOutOfRegion.urlPassthrough);
        } else {
          document.addEventListener('consentmoSignal', function(event) {
            const csmSignal = event.detail;
            const consentState = csmSignal.integration?.gcm?.isEnabled ? csmSignal.integration.gcm.state : csmSignal.state;
            gtag('consent', 'update', consentState);
            if (csmSignal.integration?.gcm?.isEnabled) { gtag('set', 'ads_data_redaction', csmSignal.integration.gcm.adsDataRedaction); gtag('set', 'url_passthrough', csmSignal.integration.gcm.urlPassthrough); }
          });
        }
      });
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="ATTIMO" />
    {noIndex ? <meta name="robots" content="noindex" /> : <meta name="robots" content="index, follow" />}
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={socialTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@attimoevoo" />
    <meta name="twitter:title" content={socialTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Caladea:ital,wght@0,400;0,700;1,400;1,700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,600&family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&display=swap" />
    <link rel="icon" type="image/png" href="/favicon.png?v=3" />

    {jsonLdArray.map((data) => <script is:inline type="application/ld+json" set:html={JSON.stringify(data)} />)}

    <script defer src="/klaro-config.js" is:inline></script>
    <link rel="stylesheet" href="https://cdn.kiprotect.com/klaro/v0.7/klaro.min.css" />
    <script defer src="https://cdn.kiprotect.com/klaro/v0.7/klaro.js" data-config="klaroConfig" is:inline></script>

    <style is:inline>
      .klaro .cookie-notice { background-color: #1B4229 !important; color: rgba(255,255,255,0.8) !important; border: none !important; border-top: none !important; border-radius: 12px !important; box-shadow: 0 12px 32px rgba(0,0,0,0.28), 0 4px 12px rgba(0,0,0,0.16) !important; position: fixed !important; bottom: 20px !important; left: 20px !important; right: auto !important; top: auto !important; width: 440px !important; max-width: calc(100vw - 40px) !important; padding: 20px !important; z-index: 99990 !important; }
      @media (max-width: 480px) { .klaro .cookie-notice { left: 12px !important; right: 12px !important; bottom: 12px !important; width: auto !important; max-width: none !important; } }
      .klaro .cookie-notice .cn-body { display: flex !important; flex-wrap: wrap !important; flex-direction: row !important; align-items: center !important; gap: 12px !important; margin: 0 !important; padding: 0 !important; }
      .klaro .cookie-notice .cn-body p { flex: 0 0 100% !important; color: rgba(255,255,255,0.8) !important; margin: 0 !important; margin-right: 0 !important; max-width: none !important; font-size: 13px !important; line-height: 1.45 !important; }
      .klaro .cookie-notice:not(.cookie-modal-notice) .cn-body .cn-learn-more { display: inline-flex !important; align-items: center !important; justify-content: center !important; height: 36px !important; padding: 0 !important; margin: 0 !important; flex-grow: 0 !important; flex-shrink: 0 !important; background: transparent !important; border: none !important; color: rgba(255,255,255,0.8) !important; text-decoration: none !important; text-transform: none !important; font-weight: 400 !important; font-size: 13px !important; line-height: 1 !important; vertical-align: middle !important; box-shadow: none !important; box-sizing: border-box !important; }
      .klaro .cookie-notice:not(.cookie-modal-notice) .cn-body .cn-ok { display: inline-flex !important; flex-direction: row !important; align-items: center !important; justify-content: flex-end !important; flex-wrap: nowrap !important; gap: 12px !important; margin: 0 !important; padding: 0 !important; height: 36px !important; }
      .klaro .cookie-notice:not(.cookie-modal-notice) .cn-body .cn-ok > a, .klaro .cookie-notice:not(.cookie-modal-notice) .cn-body .cn-ok > div { margin: 0 !important; }
      .klaro .cookie-notice:not(.cookie-modal-notice) .cn-body .cn-buttons { display: inline-flex !important; flex-direction: row !important; align-items: center !important; gap: 12px !important; margin: 0 !important; padding: 0 !important; height: 36px !important; }
      .klaro .cookie-notice .cn-ok .cm-btn, .klaro .cookie-notice .cn-buttons .cm-btn, .klaro .cookie-notice .cn-buttons button.cm-btn-success, .klaro .cookie-notice .cn-buttons button.cm-btn-danger, .klaro .cookie-notice .cn-buttons button.cn-decline, .klaro .cookie-notice .cm-btn.cm-btn-danger.cn-decline { display: inline-flex !important; align-items: center !important; justify-content: center !important; height: 36px !important; padding: 0 14px !important; margin: 0 !important; margin-top: 0 !important; margin-right: 0 !important; border-radius: 6px !important; border: 1.5px solid transparent !important; font-weight: 600 !important; font-size: 13px !important; text-transform: none !important; line-height: 1 !important; box-shadow: none !important; box-sizing: border-box !important; vertical-align: middle !important; }
      .klaro .cookie-notice .cm-btn-success { background-color: #CDDB2D !important; color: #1B4229 !important; border-color: #CDDB2D !important; }
      .klaro .cookie-notice .cm-btn.cm-btn-danger.cn-decline, .klaro .cookie-notice button.cm-btn-danger, .klaro .cookie-notice button.cn-decline { background-color: transparent !important; color: rgba(255,255,255,0.8) !important; border-color: rgba(255,255,255,0.45) !important; box-shadow: none !important; }
      .klaro .cookie-modal .cm-modal { background-color: #1B4229 !important; color: #ffffff !important; }
      .klaro .cookie-modal .cm-modal .cm-header { border-bottom: 1px solid rgba(205,219,45,0.3) !important; }
      .klaro .cookie-modal .cm-modal .cm-header h1 { color: #ffffff !important; }
      .klaro .cookie-modal .cm-modal .cm-body p, .klaro .cookie-modal .cm-modal .cm-purposes p, .klaro .cookie-modal .cm-modal p { color: rgba(255,255,255,0.9) !important; }
      .klaro .cookie-modal .cm-modal .cm-footer { border-top: 1px solid rgba(205,219,45,0.3) !important; background-color: #1B4229 !important; }
      .klaro .cookie-modal .cm-modal .cm-footer .cm-btn { padding: 8px 20px !important; }
      .klaro .cookie-modal .cm-modal .cm-btn-success, .klaro .cookie-modal .cm-modal .cm-btn-accept-all { background-color: #CDDB2D !important; color: #1B4229 !important; border: none !important; font-weight: 700 !important; }
      .klaro .cookie-modal .cm-modal .cm-btn-danger { background-color: transparent !important; color: #CDDB2D !important; border: 1px solid #CDDB2D !important; }
      .klaro .cookie-modal input:checked + .cm-list-label .slider { background-color: #CDDB2D !important; }
      .klaro .cookie-modal .cm-list-label .slider { background-color: rgba(255,255,255,0.2) !important; }
      .klaro .cookie-modal .cm-list-label .slider:before { background-color: #ffffff !important; }
      .klaro .cookie-modal .cm-modal a { color: #CDDB2D !important; }
      .klaro .cookie-modal .cm-modal .cm-list-title { color: #ffffff !important; }
      .klaro .cookie-modal .cm-modal .cm-list-description { color: rgba(255,255,255,0.7) !important; }
      .klaro .cookie-modal .cm-modal .cm-divider { border-color: rgba(205,219,45,0.2) !important; }
      .klaro .cm-bg { background-color: rgba(0,0,0,0.7) !important; }
      .klaro .cookie-modal .cm-modal .cm-header .hide, .klaro .cookie-modal .cm-modal .cm-header button.hide, .klaro .cookie-modal .cm-modal .cm-header .hide svg { color: rgba(255,255,255,0.8) !important; opacity: 0.8 !important; fill: rgba(255,255,255,0.8) !important; stroke: rgba(255,255,255,0.8) !important; }
      @media (max-width: 639px) { body.cart-open #announce-bar { display: none !important; } }
    </style>

    <!-- Google Tag Manager -->
    <script is:inline>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-T5HD4T66');
    </script>
    <!-- End Google Tag Manager -->
  </head>
  <body class={bodyClass} style={bodyStyle}>
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-T5HD4T66" height="0" width="0" style="display:none;visibility:hidden"></iframe>
    </noscript>
    <slot />
  </body>
</html>
