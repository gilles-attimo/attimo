---
import { toHTML, type PortableTextOptions } from "@portabletext/to-html";
import { urlFor } from "@/lib/sanity";

interface Props {
  value: any[];
}

const { value } = Astro.props;

function escapeHtml(unsafe: string): string {
  return unsafe
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#039;");
}

const components: PortableTextOptions["components"] = {
  types: {
    image: ({ value }) => {
      if (!value?.asset) return "";
      const src = urlFor(value).width(1200).auto("format").url();
      const alt = value.alt ? escapeHtml(value.alt) : "";
      return `<div class="my-8 rounded-xl overflow-hidden"><img src="${src}" alt="${alt}" class="w-full h-auto" loading="lazy" /></div>`;
    },
    tweet: ({ value }) => {
      if (!value?.url) return "";
      const url = String(value.url);
      const tweetId = url.split("/").pop()?.split("?")[0] || "";
      const safeUrl = escapeHtml(url);
      const safeId = escapeHtml(tweetId);
      return `<div class="my-8 tweet-embed" data-tweet-id="${safeId}"><blockquote class="twitter-tweet" data-dnt="true"><a href="${safeUrl}"></a></blockquote></div>`;
    },
    table: ({ value }) => {
      if (!value?.rows?.length) return "";
      const [header, ...rows] = value.rows;
      const headerCells = (header.cells || [])
        .map(
          (c: string) =>
            `<th class="px-5 py-3 font-semibold tracking-wide uppercase" style="font-size: 13px; letter-spacing: 0.05em;">${escapeHtml(c)}</th>`
        )
        .join("");
      const bodyRows = rows
        .map((row: any, ri: number) => {
          const bg = ri % 2 === 0 ? "#FAF9F6" : "#f5f0e8";
          const cells = (row.cells || [])
            .map(
              (c: string) =>
                `<td class="px-5 py-3" style="border-top: 1px solid #1B422915;">${escapeHtml(c)}</td>`
            )
            .join("");
          return `<tr style="background-color: ${bg};">${cells}</tr>`;
        })
        .join("");
      return `<div class="my-8 overflow-x-auto rounded-xl border" style="border-color: #1B422920;">
        <table class="w-full border-collapse text-left" style="font-family: 'Space Grotesk', sans-serif; font-size: 16px;">
          <thead><tr style="background-color: #1B4229; color: #fff;">${headerCells}</tr></thead>
          <tbody>${bodyRows}</tbody>
        </table>
      </div>`;
    },
  },
  block: {
    h1: ({ children }) =>
      `<h1 class="mt-12 mb-4 uppercase tracking-wide" style="font-family: 'UDC Working Man Sans', sans-serif; font-size: 24px; font-weight: 700; color: #1b411c;">${children}</h1>`,
    h2: ({ children }) =>
      `<h2 class="mt-12 mb-4 uppercase tracking-wide" style="font-family: 'UDC Working Man Sans', sans-serif; font-size: 26px; font-weight: 700; color: #1b411c;">${children}</h2>`,
    h3: ({ children }) =>
      `<h3 class="mt-8 mb-3" style="font-family: 'UDC Working Man Sans', sans-serif; font-size: 19px; font-weight: 600; color: #1b411c;">${children}</h3>`,
    normal: ({ children }) => `<p class="mb-6">${children}</p>`,
    blockquote: ({ children }) =>
      `<blockquote class="border-l-4 pl-6 my-8 italic" style="border-color: #CDDB2D; color: #1B4229BB;">${children}</blockquote>`,
  },
  list: {
    bullet: ({ children }) =>
      `<ul class="list-disc pl-6 mb-6 space-y-2" style="color: #1a1a1a;">${children}</ul>`,
    number: ({ children }) => `<ol class="list-decimal pl-6 mb-6 space-y-2">${children}</ol>`,
  },
  listItem: {
    bullet: ({ children }) => `<li class="leading-relaxed pl-1">${children}</li>`,
    number: ({ children }) => `<li class="leading-relaxed">${children}</li>`,
  },
  marks: {
    strong: ({ children }) =>
      `<strong class="font-semibold" style="color: #1B4229;">${children}</strong>`,
    em: ({ children }) => `<em>${children}</em>`,
    link: ({ value, children }) => {
      const href = escapeHtml(value?.href || "#");
      return `<a href="${href}" target="_blank" rel="noopener noreferrer" class="underline" style="color: #1B4229;">${children}</a>`;
    },
  },
};

const html = toHTML(value || [], { components });
const hasTweet = (value || []).some((b: any) => b?._type === "tweet");
---

<div set:html={html} />

{hasTweet && (
  <script async src="https://platform.twitter.com/widgets.js" charset="utf-8"></script>
)}
