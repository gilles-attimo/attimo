---
// Static header — always uses the "scrolled" dark-green styling on internal pages like /blog
// (matches `forceScrolled` in the React Header).
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 py-6 shadow-lg"
  style="background-color: #1B4229; transition: box-shadow 0.3s ease, background-color 0.3s ease;"
>
  <div class="container mx-auto px-6">
    <div class="flex items-center justify-between">
      <div class="flex items-center">
        <a href="/">
          <img
            src="/assets/navbar-logo.svg"
            alt="ATTIMO"
            class="h-7 md:h-9 lg:h-11 w-auto"
          />
        </a>
      </div>
      <div class="flex items-center gap-3 md:gap-6 ml-auto">
        <a
          href="/#shop"
          class="text-white hover:opacity-80 transition-opacity text-base md:text-lg font-medium"
          style="font-family: 'Space Grotesk', sans-serif;"
        >
          Shop
        </a>
        <a
          href="/blog"
          class="text-white hover:opacity-80 transition-opacity text-base md:text-lg font-medium"
          style="font-family: 'Space Grotesk', sans-serif;"
        >
          Blog
        </a>
        <a href="/" id="nav-cart-link" aria-label="Cart" class="text-white hover:opacity-80 transition-opacity">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <path d="M16 10a4 4 0 1 1-8 0"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</header>
