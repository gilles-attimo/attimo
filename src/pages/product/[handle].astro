---
import BaseLayout from "@astro/layouts/BaseLayout.astro";
import ProductPageWrapper from "@astro/react-pages/ProductPageWrapper";
import { aggregateRating, reviews } from "@/lib/reviewSchema";
import { fetchProducts, fetchSellingPlans } from "@/lib/shopify";
import { resolveShopifyHandle } from "@/lib/productContent";

export function getStaticPaths() {
  return [
    { params: { handle: "coratina" } },
    { params: { handle: "nocellara" } },
    { params: { handle: "picual" } },
  ];
}

const { handle } = Astro.params as { handle: "coratina" | "nocellara" | "picual" };
const shopifyHandle = resolveShopifyHandle(handle);

const [allProducts, exactHandleProducts, sellingPlans] = await Promise.all([
  fetchProducts(50).catch(() => []),
  shopifyHandle ? fetchProducts(1, `handle:${shopifyHandle}`).catch(() => []) : Promise.resolve([]),
  shopifyHandle ? fetchSellingPlans(shopifyHandle).catch(() => []) : Promise.resolve([]),
]);

const initialProducts = [...allProducts, ...exactHandleProducts].filter(
  (product, index, arr) => arr.findIndex((p) => p.node.id === product.node.id) === index
);

interface Meta {
  title: string;
  description: string;
  image: string;
  productName: string;
  sku: string;
  polyphenols: string;
}

const META: Record<typeof handle, Meta> = {
  coratina: {
    title: "Attimo Coratina Extra Virgin Olive Oil | 847mg/kg Polyphenols",
    description:
      "Single-variety Coratina extra virgin olive oil from Puglia. Early harvest, cold-pressed. 847mg/kg polyphenols — lab tested. Certified organic. 500ml.",
    image: "https://cdn.shopify.com/s/files/1/0949/7867/0975/files/Coratina-2_1_1.png?v=1773399330",
    productName: "Attimo Coratina Extra Virgin Olive Oil 500ml",
    sku: "ATTIMO-COR-500",
    polyphenols: "847",
  },
  nocellara: {
    title: "Attimo Nocellara Extra Virgin Olive Oil | 400mg/kg Polyphenols",
    description:
      "Single-variety Nocellara extra virgin olive oil from Sicily. Early harvest, cold-pressed. 400mg/kg polyphenols — lab tested. 500ml.",
    image: "https://cdn.shopify.com/s/files/1/0949/7867/0975/files/NOCELLARA1_1.png?v=1772735243",
    productName: "Attimo Nocellara Extra Virgin Olive Oil 500ml",
    sku: "ATTIMO-NOC-500",
    polyphenols: "400",
  },
  picual: {
    title: "Attimo Picual Extra Virgin Olive Oil | 675mg/kg Polyphenols",
    description:
      "Single-variety Picual extra virgin olive oil from Andalusia. Early harvest, cold-pressed. 675mg/kg polyphenols — lab tested. 500ml.",
    image: "https://cdn.shopify.com/s/files/1/0949/7867/0975/files/Picual-v21.png?v=1773401549",
    productName: "Attimo Picual Extra Virgin Olive Oil 500ml",
    sku: "ATTIMO-PIC-500",
    polyphenols: "675",
  },
};

const meta = META[handle];
const canonicalUrl = `https://attimo-oil.com/product/${handle}`;

const productJsonLd = {
  "@context": "https://schema.org/",
  "@type": "Product",
  name: meta.productName,
  description: meta.description,
  sku: meta.sku,
  brand: { "@type": "Brand", name: "Attimo" },
  image: meta.image,
  offers: {
    "@type": "Offer",
    url: canonicalUrl,
    price: "24.00",
    priceCurrency: "EUR",
    availability: "https://schema.org/InStock",
    itemCondition: "https://schema.org/NewCondition",
  },
  aggregateRating,
  review: reviews,
};
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  canonical={canonicalUrl}
  ogImage={meta.image}
  ogType="product"
  bodyStyle="background-color: #FFFAEA;"
  jsonLd={productJsonLd}
>
  <script is:inline define:vars={{ handle }}>
    if (typeof window !== "undefined") window.__ASTRO_PARAMS__ = { handle };
  </script>
  <ProductPageWrapper
    handle={handle}
    initialProducts={initialProducts}
    initialSellingPlans={sellingPlans}
    client:load
  />
</BaseLayout>
