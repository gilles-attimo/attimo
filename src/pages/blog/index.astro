---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getAllPosts, urlFor } from "@/lib/sanity";

const posts = await getAllPosts();

const formatDate = (dateStr: string) =>
  new Date(dateStr).toLocaleDateString("en-US", { month: "long", year: "numeric" });
---

<BaseLayout
  title="The Olive Press — ATTIMO Blog"
  description="Stories, science, and sourcing behind high-polyphenol extra virgin olive oil."
  canonical="https://attimo-oil.com/blog"
>
  <div class="min-h-screen flex flex-col" style="background-color: #FAF9F6;">
    <Header />

    <main class="flex-1 px-6 md:px-12 lg:px-20">
      <div class="max-w-6xl mx-auto">
        <h1
          class="tracking-tight leading-[0.95]"
          style="font-family: 'Beverly Drive', cursive; font-size: clamp(3rem, 6vw, 7rem); color: #1B4229; padding-top: 200px; padding-bottom: 8px;"
        >
          The Olive Press
        </h1>

        {
          posts.length === 0 ? (
            <p class="text-center py-20 text-lg" style="font-family: 'UDC Working Man Sans', sans-serif; color: #1B422966;">
              No posts yet — check back soon.
            </p>
          ) : (
            <div
              class="grid grid-cols-1 md:grid-cols-3"
              style="gap: 32px; padding-top: 48px; padding-bottom: 80px;"
            >
              {posts.map((post) => (
                <a href={`/blog/${post.slug.current}`} class="group block">
                  <div class="rounded-xl overflow-hidden" style="aspect-ratio: 16/9; background-color: #1B422910;">
                    {post.coverImage ? (
                      <img
                        src={urlFor(post.coverImage).width(960).auto("format").url()}
                        alt={post.title}
                        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                        loading="lazy"
                      />
                    ) : (
                      <div class="w-full h-full flex items-center justify-center">
                        <span style="font-family: 'UDC Working Man Sans', sans-serif; font-size: 14px; color: #1B422940;">No image</span>
                      </div>
                    )}
                  </div>

                  <span
                    class="block tracking-wide"
                    style="font-family: 'UDC Working Man Sans', sans-serif; font-size: 16px; color: #1B422980; margin-top: 12px;"
                  >
                    {formatDate(post.publishedAt)}
                  </span>
                  <h2
                    class="uppercase"
                    style="font-family: 'UDC Working Man Sans', sans-serif; font-size: 26px; color: #1b411c; margin-top: 4px;"
                  >
                    {post.title}
                  </h2>
                  {post.excerpt && (
                    <p style="font-family: 'Space Grotesk', sans-serif; font-size: 20px; line-height: 1.8; color: #555; margin-top: 8px;">
                      {post.excerpt}
                    </p>
                  )}
                </a>
              ))}
            </div>
          )
        }
      </div>
    </main>

    <Footer />
  </div>
</BaseLayout>
